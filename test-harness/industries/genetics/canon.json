      "id": "MENDEL_SEG_01",
      "name": "Mendelian Segregation",
      "expression_latex": "P(A) = \\frac{1}{2}",
      "expression_pddl": "(= (allele-probability ?gene dominant) 0.5)",
      "status": "CANONICAL",
      "domain": "Genetics",
      "variables": ["P", "A"]
    },
    {
      "id": "MENDEL_ASSORT_02",
      "name": "Independent Assortment",
      "expression_latex": "P(A \\cap B) = P(A) \\cdot P(B)",
      "expression_pddl": "(= (joint-probability ?gene-A ?gene-B) (* (probability ?gene-A) (probability ?gene-B)))",
      "status": "CANONICAL",
      "domain": "Genetics",
      "variables": ["P", "A", "B"]
    },
    {
      "id": "HARDY_WEINBERG_03",
      "name": "Hardy–Weinberg Equilibrium",
      "expression_latex": "p^2 + 2pq + q^2 = 1",
      "expression_pddl": "(= (+ (expt p 2) (+ (* 2 (* p q)) (expt q 2))) 1)",
      "status": "CANONICAL",
      "domain": "Genetics",
      "variables": ["p", "q"]
    }
  ]
}
